<section class="section{% if section.settings.background == 'navy' %} section--navy{% endif %}">
  <div class="container">
    <div class="editorial{% if section.settings.reverse %} editorial--reverse{% endif %}">
      <div class="editorial__image-wrap">
        {%- if section.settings.image != blank -%}
          <img
            src="{{ section.settings.image | image_url: width: 900 }}"
            srcset="
              {{ section.settings.image | image_url: width: 600 }} 600w,
              {{ section.settings.image | image_url: width: 900 }} 900w,
              {{ section.settings.image | image_url: width: 1200 }} 1200w
            "
            sizes="(max-width: 768px) 100vw, 55vw"
            alt="{{ section.settings.image.alt | escape }}"
            loading="lazy"
            width="{{ section.settings.image.width }}"
            height="{{ section.settings.image.height }}"
          >
        {%- else -%}
          <div style="width:100%;height:100%;background:var(--ab-sand-soft);"></div>
        {%- endif -%}
      </div>

      <div class="editorial__body">
        {%- if section.settings.eyebrow != blank -%}
          <div class="editorial__eyebrow">{{ section.settings.eyebrow }}</div>
        {%- endif -%}

        {%- if section.settings.title != blank -%}
          <h2 class="editorial__title">{{ section.settings.title }}</h2>
        {%- endif -%}

        {%- if section.settings.copy != blank -%}
          <p class="editorial__copy">{{ section.settings.copy }}</p>
        {%- endif -%}

        {%- if section.settings.link_label != blank -%}
          <a
            href="{{ section.settings.link_url | default: '#' }}"
            class="editorial__link"
          >{{ section.settings.link_label }} →</a>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Editorial (2-up)",
  "settings": [
    {
      "type": "select",
      "id": "background",
      "label": "Background",
      "options": [
        { "value": "sand", "label": "Sand (default)" },
        { "value": "navy", "label": "Navy" }
      ],
      "default": "sand"
    },
    {
      "type": "checkbox",
      "id": "reverse",
      "label": "Reverse layout (image right)",
      "default": false
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Journal · No. 01"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "A weekend at the desert house"
    },
    {
      "type": "textarea",
      "id": "copy",
      "label": "Copy",
      "default": "On parasol scallops, terrazzo at noon, and the case for arriving an hour before the table is set."
    },
    {
      "type": "text",
      "id": "link_label",
      "label": "Link label",
      "default": "Read the journal"
    },
    {
      "type": "url",
      "id": "link_url",
      "label": "Link URL"
    }
  ],
  "presets": [
    {
      "name": "Editorial (2-up)",
      "settings": {
        "eyebrow": "Journal · No. 01",
        "title": "A weekend at the desert house",
        "copy": "On parasol scallops, terrazzo at noon, and the case for arriving an hour before the table is set.",
        "link_label": "Read the journal"
      }
    }
  ]
}
{% endschema %}

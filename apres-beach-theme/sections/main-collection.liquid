<div class="collection-page">
  <div class="container">
    <div class="collection-header">
      {%- if collection.image -%}
        <div style="aspect-ratio:3/1;overflow:hidden;margin-bottom:var(--sp-7);">
          <img
            src="{{ collection.image | image_url: width: 1600 }}"
            alt="{{ collection.image.alt | escape }}"
            loading="eager"
            style="width:100%;height:100%;object-fit:cover;"
          >
        </div>
      {%- endif -%}

      <div class="eyebrow" style="margin-bottom:var(--sp-3);">{{ collection.products_count }} pieces</div>
      <h1 class="collection-header__title">{{ collection.title }}</h1>
      {%- if collection.description != blank -%}
        <div class="collection-header__description">{{ collection.description }}</div>
      {%- endif -%}
    </div>

    <div class="product-grid">
      {%- for product in collection.products -%}
        {%- render 'product-card', product: product -%}
      {%- else -%}
        <p style="grid-column:1/-1;color:var(--fg2);">No products found in this collection.</p>
      {%- endfor -%}
    </div>

    {%- if paginate.pages > 1 -%}
      {%- paginate collection.products by 16 -%}
        <nav class="pagination" aria-label="Collection pagination">
          {%- if paginate.previous -%}
            <a href="{{ paginate.previous.url }}" class="pagination__item">←</a>
          {%- endif -%}
          {%- for part in paginate.parts -%}
            {%- if part.is_link -%}
              <a href="{{ part.url }}" class="pagination__item">{{ part.title }}</a>
            {%- else -%}
              <span class="pagination__item is-active">{{ part.title }}</span>
            {%- endif -%}
          {%- endfor -%}
          {%- if paginate.next -%}
            <a href="{{ paginate.next.url }}" class="pagination__item">→</a>
          {%- endif -%}
        </nav>
      {%- endpaginate -%}
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Collection",
  "settings": []
}
{% endschema %}

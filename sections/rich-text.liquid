<section class="section{% if section.settings.background == 'navy' %} section--navy{% endif %}">
  <div class="container">
    <div class="rich-text{% if section.settings.align == 'center' %} rich-text--center{% endif %}">
      {%- if section.settings.eyebrow != blank -%}
        <div class="eyebrow rich-text__eyebrow">{{ section.settings.eyebrow }}</div>
      {%- endif -%}

      {%- if section.settings.title != blank -%}
        <h2 class="rich-text__title">{{ section.settings.title }}</h2>
      {%- endif -%}

      {%- if section.settings.copy != blank -%}
        <div class="rich-text__copy">{{ section.settings.copy }}</div>
      {%- endif -%}

      {%- if section.settings.cta_label != blank -%}
        <div class="rich-text__cta">
          <a
            href="{{ section.settings.cta_url | default: '#' }}"
            class="btn btn--{% if section.settings.background == 'navy' %}sand{% else %}primary{% endif %}"
          >{{ section.settings.cta_label }}</a>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Rich text",
  "settings": [
    {
      "type": "select",
      "id": "background",
      "label": "Background",
      "options": [
        { "value": "sand", "label": "Sand (default)" },
        { "value": "navy", "label": "Navy" }
      ],
      "default": "sand"
    },
    {
      "type": "select",
      "id": "align",
      "label": "Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ],
      "default": "left"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title"
    },
    {
      "type": "richtext",
      "id": "copy",
      "label": "Copy"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button URL"
    }
  ],
  "presets": [
    {
      "name": "Rich text",
      "settings": {
        "title": "We make linen for after the swim"
      }
    }
  ]
}
{% endschema %}

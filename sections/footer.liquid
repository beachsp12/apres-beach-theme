<footer class="site-footer" role="contentinfo">
  <div class="site-footer__inner">
    <div class="site-footer__wordmark" aria-hidden="true">{{ shop.name }}</div>

    <div class="site-footer__cols">
      {%- for block in section.blocks -%}
        {%- if block.type == 'link_list' -%}
          <div {{ block.shopify_attributes }}>
            <div class="site-footer__col-title">{{ block.settings.heading }}</div>
            {%- if block.settings.menu != blank -%}
              <ul class="site-footer__col-links">
                {%- for link in linklists[block.settings.menu].links -%}
                  <li><a href="{{ link.url }}">{{ link.title }}</a></li>
                {%- endfor -%}
              </ul>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}

      <div>
        <div class="site-footer__col-title">{{ section.settings.newsletter_heading }}</div>
        <p class="site-footer__newsletter-text">{{ section.settings.newsletter_text }}</p>
        {%- form 'customer', class: 'site-footer__newsletter-form js-newsletter-form' -%}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <input
            type="email"
            name="contact[email]"
            class="site-footer__newsletter-input"
            placeholder="Email"
            required
            autocomplete="email"
            aria-label="Email address"
          >
          <button type="submit" class="site-footer__newsletter-btn">Subscribe →</button>
        {%- endform -%}
      </div>
    </div>

    <div class="site-footer__bottom">
      <div>© {{ shop.name }} · {{ 'now' | date: '%Y' }}</div>
      <div class="site-footer__legal">
        {%- if linklists['footer'].links != blank -%}
          {%- for link in linklists['footer'].links -%}
            <a href="{{ link.url }}">{{ link.title }}</a>
          {%- endfor -%}
        {%- else -%}
          <a href="/policies/privacy-policy">Privacy</a>
          <a href="/policies/terms-of-service">Terms</a>
          <a href="/policies/refund-policy">Returns</a>
        {%- endif -%}
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "text",
      "id": "newsletter_heading",
      "label": "Newsletter column heading",
      "default": "The dispatch"
    },
    {
      "type": "textarea",
      "id": "newsletter_text",
      "label": "Newsletter description",
      "default": "A note from the maison every few weeks. New arrivals, the editorial, where to find us next."
    }
  ],
  "blocks": [
    {
      "type": "link_list",
      "name": "Footer menu column",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Column heading",
          "default": "Shop"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu",
          "default": "footer"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Footer",
      "blocks": [
        { "type": "link_list", "settings": { "heading": "Shop", "menu": "main-menu" } },
        { "type": "link_list", "settings": { "heading": "Maison", "menu": "footer" } },
        { "type": "link_list", "settings": { "heading": "Service", "menu": "footer" } }
      ]
    }
  ]
}
{% endschema %}
